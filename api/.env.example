# Configuración de la API - Sistema de Gestión Escolar (SGE)
# Copiar este archivo a .env y ajustar los valores según el entorno

# Puerto del servidor
PORT=3001

# Clave secreta para JWT (cambiar en producción)
JWT_SECRET=sge-secret-key-2024-change-this-in-production

# Entorno de ejecución
NODE_ENV=development

# Configuración de base de datos (opcional para futuro)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=sge_db
# DB_USER=sge_user
# DB_PASSWORD=sge_password

# Configuración de CORS (dominios permitidos)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080

# Configuración de uploads
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Configuración de logs
LOG_LEVEL=info
LOG_PATH=./logs

# Configuración de rate limiting (futuro)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Configuración de cache (futuro)
CACHE_TTL=3600
CACHE_HOST=localhost
CACHE_PORT=6379
